# ============================================================
# contrib-wall — wrangler.toml 配置模板
# ============================================================
# 使用方法：
#   cp wrangler.toml.example wrangler.toml
#   然后替换 <YOUR_...> 占位符为你自己的值。
#
# ⚠️  wrangler.toml 包含你的 KV namespace ID 等私有配置，
#     已在 .gitignore 中排除，请勿提交到仓库。
# ============================================================

name = "contrib-wall"
main = "src/index.ts"
compatibility_date = "2026-07-08"
workers_dev = true
assets = { directory = "./frontend/dist", binding = "assets" }

# ------------------------------------------------------------
# KV 存储
# ------------------------------------------------------------
# 用来保存贡献者快照和缓存数据。
#
# 创建 KV namespace：
#   npx wrangler kv namespace create contrib-wall-kv
#
# 命令执行后会输出 id，填入下方即可。
# ⚠️  必须在此处声明，否则每次 wrangler deploy 都会覆盖
#     Dashboard 上手动添加的绑定，导致 KV 绑定丢失。
[[kv_namespaces]]
binding = "kv"
id = "<YOUR_KV_NAMESPACE_ID>"

# ------------------------------------------------------------
# 构建
# ------------------------------------------------------------
[build]
command = "cd frontend && npm install && npm run build"

# ------------------------------------------------------------
# 环境变量
# ------------------------------------------------------------
[vars]
SERVICE_NAME = "contrib-wall"
GITHUB_API_BASE = "https://api.github.com"

# SVG 图片响应缓存时间（秒）。默认 86400 = 1 天。
IMAGE_CACHE_TTL_SECONDS = "86400"

# 贡献者数据自动刷新间隔（秒）。默认每天刷新一次。
CONTRIB_REFRESH_INTERVAL_SECONDS = "86400"

# true: /image 必须带 snapshot + sealed_token 才能访问。
REQUIRE_SNAPSHOT_TOKEN = "true"

# 可选：限制可生成快照的仓库列表，逗号分隔。
# 为空代表允许任意仓库。
# 示例：ALLOWED_REPOS = "nyakang/nyaterm,nyakang/docs-site"
ALLOWED_REPOS = ""

# 简单防刷：每个 IP 每小时最多生成多少次快照。
# 设为 0 可关闭限制。
GENERATE_RATE_LIMIT_PER_HOUR = "30"

# ------------------------------------------------------------
# Secrets（不要写在这里，通过以下方式设置）
# ------------------------------------------------------------
# SEALING_SECRET — 用于签名和验证 sealed token 的密钥。
#   至少 32 个字符的随机字符串。
#
#   生成方式：openssl rand -base64 48
#   设置方式：npx wrangler secret put SEALING_SECRET
#
#   本地开发：复制 .dev.vars.example 为 .dev.vars 并填入。
